# Copy this file to .env and fill in the values
# cp .env.example .env

# ── Shared ────────────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
CORS_ALLOW_ALL_ORIGINS=True

# ── drone-service database ────────────────────────────────────────────────────
DRONE_DB_NAME=vesper_drones
DRONE_DB_USER=vesper
DRONE_DB_PASSWORD=vesper_drones_secret_change_in_prod
DRONE_DB_HOST=db-drones
DRONE_DB_PORT=5432

# ── mission-service database ──────────────────────────────────────────────────
MISSION_DB_NAME=vesper_missions
MISSION_DB_USER=vesper
MISSION_DB_PASSWORD=vesper_missions_secret_change_in_prod
MISSION_DB_HOST=db-missions
MISSION_DB_PORT=5432

# ── Inter-service communication ───────────────────────────────────────────────
DRONE_SERVICE_URL=http://drone-service:8001

# ── Frontend ──────────────────────────────────────────────────────────────────
# All traffic goes through nginx on port 8000
VITE_API_BASE_URL=http://localhost:8000/api
